---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;
const status = Astro.url.searchParams.get('status');
const alert = status === 'success'
  ? 'Contraseña actualizada correctamente. Ahora puedes iniciar sesión con tu nueva contraseña.'
  : status === 'match-error'
  ? 'Las contraseñas nuevas no coinciden. Por favor verifica y vuelve a intentarlo.'
  : null;
---

<BaseLayout pageTitle="Cambiar Contraseña">
  <section class="flex min-h-[80vh] items-center justify-center px-4 py-12 sm:px-6">
    <div class="w-full max-w-2xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-xl">
      <div class="text-center mb-8">
        <p class="text-xs uppercase tracking-[0.35em] text-cyan-600">Seguridad</p>
        <h1 class="mt-3 text-3xl font-semibold text-slate-900">Cambiar contraseña</h1>
        <p class="mt-3 text-sm leading-6 text-slate-600">Actualiza tu acceso seguro y protege el panel de administración.</p>
      </div>

      {alert && (
        <div class="mb-6 rounded-3xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm text-emerald-900 shadow-sm">
          {alert}
        </div>
      )}

      <form action="/api/auth/change-password" method="POST" class="space-y-6">
        <label class="block">
          <span class="text-sm font-semibold text-slate-700">Contraseña actual</span>
          <input
            type="password"
            name="currentPassword"
            required
            placeholder="Contraseña actual"
            class="mt-2 w-full rounded-3xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500"
          />
        </label>

        <label class="block">
          <span class="text-sm font-semibold text-slate-700">Nueva contraseña</span>
          <input
            type="password"
            name="newPassword"
            required
            placeholder="Nueva contraseña"
            class="mt-2 w-full rounded-3xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500"
          />
        </label>

        <label class="block">
          <span class="text-sm font-semibold text-slate-700">Confirmar nueva contraseña</span>
          <input
            type="password"
            name="confirmPassword"
            required
            placeholder="Repite la nueva contraseña"
            class="mt-2 w-full rounded-3xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500"
          />
        </label>

        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <a href="/admin" class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-cyan-300 hover:text-cyan-700">
            Volver al panel
          </a>
          <button type="submit" class="inline-flex items-center justify-center rounded-full bg-cyan-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-cyan-600/20 transition hover:bg-cyan-500 hover:shadow-cyan-500/30">
            Guardar contraseña
          </button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
