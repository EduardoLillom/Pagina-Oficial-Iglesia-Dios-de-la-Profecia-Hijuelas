---
import AdminLayout from '../../layouts/AdminLayout.astro';

export const prerender = false;
const status = Astro.url.searchParams.get('status');
const alert = status === 'post-created'
  ? 'Publicación creada correctamente. Aquí puedes continuar agregando más contenido.'
  : status === 'post-failed'
  ? 'Error: el título del post es obligatorio.'
  : null;
---

<AdminLayout pageTitle="Panel Administrativo">
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col gap-4 rounded-4xl border border-slate-200 bg-slate-50 p-8 shadow-sm sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-cyan-600">Panel administrativo</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">Gestiona tus publicaciones</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">Agrega nuevos posts, revisa el estado de tu sitio y amplía esta zona de administración cuando quieras.</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href="/admin/change-password" class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-cyan-300 hover:text-cyan-700">
          Cambiar contraseña
        </a>
        <form action="/api/auth/signout" method="GET" class="inline-block">
          <button type="submit" class="inline-flex items-center justify-center rounded-full bg-cyan-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-cyan-600/20 transition hover:bg-cyan-500 hover:shadow-cyan-500/30">
            Cerrar sesión
          </button>
        </form>
      </div>
    </div>

    {alert && (
      <div class="mb-8 rounded-3xl border border-emerald-200 bg-emerald-50 px-6 py-4 text-sm text-emerald-900 shadow-sm">
        {alert}
      </div>
    )}

    <div class="grid gap-6 xl:grid-cols-[1.45fr_0.85fr]">
      <div class="space-y-6">
        <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
          <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-xs uppercase tracking-[0.35em] text-slate-400">Agregar post</p>
              <h2 class="mt-2 text-2xl font-semibold text-slate-900">Nuevo contenido para la web</h2>
            </div>
            <span class="inline-flex items-center rounded-full bg-cyan-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.35em] text-cyan-700">Listo para ampliar</span>
          </div>

          <form action="/api/admin/post" method="POST" class="space-y-6">
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="text-sm font-semibold text-slate-700">Título</span>
                <input name="title" type="text" placeholder="Título del post" class="mt-2 w-full rounded-3xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500" required />
              </label>

              <label class="block">
                <span class="text-sm font-semibold text-slate-700">Categoría</span>
                <select name="category" class="mt-2 w-full rounded-3xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500">
                  <option>General</option>
                  <option>Noticias</option>
                  <option>Eventos</option>
                  <option>Testimonios</option>
                </select>
              </label>
            </div>

            <label class="block">
              <span class="text-sm font-semibold text-slate-700">Extracto</span>
              <textarea name="excerpt" rows="3" placeholder="Resumen breve de la publicación" class="mt-2 w-full rounded-3xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500"></textarea>
            </label>

            <label class="block">
              <span class="text-sm font-semibold text-slate-700">Contenido</span>
              <textarea name="content" rows="6" placeholder="Escribe aquí el texto completo del post" class="mt-2 w-full rounded-3xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500"></textarea>
            </label>

            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <label class="inline-flex items-center gap-3 rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 transition hover:border-cyan-300">
                <input type="checkbox" name="publish" class="h-4 w-4 rounded border-slate-300 text-cyan-600 focus:ring-cyan-500" />
                Publicar inmediatamente
              </label>

              <button type="submit" class="inline-flex items-center justify-center rounded-full bg-cyan-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-cyan-600/20 transition hover:bg-cyan-500 hover:shadow-cyan-500/30">
                Guardar post
              </button>
            </div>
          </form>
        </section>

        <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.35em] text-slate-400">Información rápida</p>
              <h2 class="mt-2 text-2xl font-semibold text-slate-900">¿Qué puedes hacer aquí?</h2>
            </div>
          </div>

          <div class="mt-6 grid gap-4 sm:grid-cols-3">
            <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
              <p class="text-sm font-semibold text-slate-900">Publicar</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Añade entradas nuevas con título, extracto y contenido.</p>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
              <p class="text-sm font-semibold text-slate-900">Editar</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Próximamente podrás gestionar los posts existentes desde aquí.</p>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
              <p class="text-sm font-semibold text-slate-900">Seguridad</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Accede al cambio de contraseña seguro en el botón superior.</p>
            </div>
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <div class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Panel rápido</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">Estas acciones también estarán disponibles más adelante en el panel de administración.</p>

          <div class="mt-6 space-y-4">
            <div class="flex items-center gap-3 rounded-3xl border border-slate-200 bg-slate-50 p-4">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-cyan-100 text-cyan-700">+</span>
              <div>
                <p class="text-sm font-semibold text-slate-900">Gestor de categorías</p>
                <p class="text-sm text-slate-600">Añade y organiza categorías de publicaciones.</p>
              </div>
            </div>
            <div class="flex items-center gap-3 rounded-3xl border border-slate-200 bg-slate-50 p-4">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-cyan-100 text-cyan-700">📌</span>
              <div>
                <p class="text-sm font-semibold text-slate-900">Vista de borradores</p>
                <p class="text-sm text-slate-600">Trabaja en publicaciones antes de publicarlas en vivo.</p>
              </div>
            </div>
            <div class="flex items-center gap-3 rounded-3xl border border-slate-200 bg-slate-50 p-4">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-cyan-100 text-cyan-700">⚙️</span>
              <div>
                <p class="text-sm font-semibold text-slate-900">Ajustes</p>
                <p class="text-sm text-slate-600">Mejoras futuras: SEO, permisos y estadísticas.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-4xl border border-slate-200 bg-slate-50 p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Próximas mejoras</h3>
          <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-600">
            <li>• Gestión de posts existentes</li>
            <li>• Borradores y revisiones</li>
            <li>• Publicación programada</li>
            <li>• Control de usuarios y roles</li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</AdminLayout>
