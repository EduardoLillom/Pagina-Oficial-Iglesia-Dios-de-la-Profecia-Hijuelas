---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getActivePosts } from '../../../lib/posts';

// 1. Obtenemos los datos reales desde la BD
const featuredItems = await getActivePosts();
---

<AdminLayout title="Contenido Destacado">
  <div class="mx-auto max-w-4xl">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Contenido Destacado</h1>
        <p class="text-sm text-slate-500">Arrastra para reordenar la prioridad.</p>
      </div>
      <a href="/admin/contenido-destacado/nuevo" class="bg-cyan-600 text-white px-4 py-2 rounded-full text-sm font-semibold hover:bg-cyan-700 transition">
        + Agregar nuevo
      </a>
    </div>

    <ul id="sortable-list" class="flex flex-col gap-3">
      {featuredItems.map((item) => (
        <li 
          data-id={item.id} 
          class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm hover:border-cyan-300 transition-colors"
        >
          <div class="cursor-grab text-slate-300 hover:text-cyan-600 active:cursor-grabbing p-2">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"></path>
            </svg>
          </div>

          <div class="flex-1">
            <h4 class="font-semibold text-slate-900">{item.title}</h4>
            <p class="text-xs text-slate-500">{item.summary || item.type}</p>
          </div>

          <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button class="px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-cyan-600">Editar</button>
            <form action="/api/admin/post" method="POST" class="inline">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={item.id} />
              <button type="submit" class="px-3 py-1.5 text-xs font-medium text-red-500 hover:text-red-700">Eliminar</button>
            </form>
          </div>
        </li>
      ))}
    </ul>
  </div>
</AdminLayout>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js" is:inline></script>

<script>
  declare var Sortable: any;

  function initSortable() {
    const list = document.getElementById('sortable-list') as HTMLElement;
    if (!list) return;
    
    new Sortable(list, {
      handle: '.cursor-grab',
      animation: 100,
      onEnd: async (evt: any) => {
        const items = Array.from(list.children).map((li, index) => ({
          id: (li as HTMLElement).dataset.id,
          newPriority: list.children.length - index // Lógica simple de prioridad
        }));

        // Aquí llamarías a tu API para guardar el nuevo orden
        console.log("Nuevo orden enviado:", items);
      }
    });
  }

  document.addEventListener('astro:page-load', initSortable);
</script>