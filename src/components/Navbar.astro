---
// src/components/Navbar.astro
const pathname = Astro.url.pathname;

const navItems = [
  { to: '/', label: 'Inicio' },
  { 
    label: 'Sobre Nosotros', 
    dropdown: [
      { title: 'Sobre Nosotros', links: [{ to: '/quienes-somos', label: 'Quiénes somos' }, { to: '/doctrina', label: 'Doctrina' }] },
    ] 
  },
  { to: '/contacto', label: 'Contacto' },
];
---

<header class="fixed top-4 left-0 right-0 z-50 px-2 sm:px-4">
  <div class="mx-auto flex max-w-5xl items-center justify-between rounded-full border border-slate-200/50 bg-white/80 px-4 py-3 shadow-lg backdrop-blur-xl">
    
    <a href="/" class="flex items-center gap-2 pl-2 shrink-0">
      <div class="h-9 w-9 shrink-0 sm:h-10 sm:w-10">
        <img src="/logo.webp" alt="Logo IDP Hijuelas" class="h-full w-full object-contain" />
      </div>
      <div class="flex flex-col min-w-0">
        <p class="text-xs font-semibold text-slate-900 truncate sm:text-sm">IDP Hijuelas</p>
        <p class="text-[10px] sm:text-xs uppercase tracking-[0.15em] sm:tracking-[0.28em] text-slate-500 truncate">
            Fe, unidad y santidad
        </p>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-lg font-medium text-slate-700">
      {navItems.map((item) => (
        item.dropdown ? (
          <div class="relative group">
            <button class="flex items-center gap-1 transition-colors hover:text-cyan-600">
              {item.label}
              <span class="text-[10px] opacity-50">▼</span>
            </button>
            
            <div class="absolute left-1/2 -translate-x-1/2 top-[calc(100%+24px)] w-max min-w-[200px] rounded-3xl border border-slate-200/50 bg-slate-900 p-6 text-white shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
              <div class="flex gap-8">
                {item.dropdown.map((col) => (
                  <div class="flex flex-col gap-3">
                    <h4 class="font-bold text-cyan-400 text-sm uppercase tracking-wider border-b border-slate-700 pb-2 whitespace-nowrap">{col.title}</h4>
                    <ul class="flex flex-col gap-2">
                      {col.links.map((link) => (
                        <li>
                          <a href={link.to} class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all block whitespace-nowrap">{link.label}</a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.to} class={`transition-colors ${pathname === item.to ? 'text-cyan-600 font-semibold' : 'hover:text-cyan-600'}`}>
            {item.label}
          </a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <button id="menu-toggle" class="md:hidden flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-700 hover:bg-slate-200 transition">
        <span id="menu-icon">≡</span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-2 right-2 mt-2 rounded-3xl border border-slate-200/50 bg-white/95 p-4 shadow-xl backdrop-blur-xl md:hidden">
    <nav class="flex flex-col gap-2">
      {navItems.map((item) => (
        item.dropdown ? (
          <div class="px-4 py-2">
            <p class="font-bold text-slate-400 uppercase text-xs mb-1">{item.label}</p>
            {item.dropdown.map(col => (
              <div class="ml-2">
                {col.links.map(link => (
                  <a href={link.to} class="block py-2 text-slate-700 hover:text-cyan-600">{link.label}</a>
                ))}
              </div>
            ))}
          </div>
        ) : (
          <a href={item.to} class="px-4 py-3 rounded-xl hover:bg-slate-100 transition font-medium text-slate-700">{item.label}</a>
        )
      ))}
    </nav>
  </div>
</header>

<script>
  function setupMenu() {
    const toggleBtn = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    toggleBtn?.addEventListener('click', () => {
      const isHidden = mobileMenu?.classList.toggle('hidden');
      if (menuIcon) menuIcon.textContent = isHidden ? '≡' : '×';
    });
  }
  setupMenu();
  document.addEventListener('astro:after-swap', setupMenu);
</script>