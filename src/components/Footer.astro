---
// src/components/Footer.astro
---
<footer class="bg-slate-950 border-t border-slate-900 text-slate-400">
  <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-xs">
    
    <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3">
      <div class="flex items-center gap-1.5">
        <span class="font-black tracking-wider text-cyan-400 uppercase text-[11px]">IDP Hijuelas</span>
        <span class="h-1 w-1 rounded-full bg-slate-700 hidden sm:inline"></span>
      </div>
      <p class="text-slate-500 text-[11px]">
        Calle Falsa 123, Hijuelas &bull; contacto@idiglesia.cl
      </p>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6">
      <nav class="flex flex-wrap gap-x-4 gap-y-1 font-medium">
        <a href="/" class="transition-colors hover:text-cyan-400">Inicio</a>
        <a href="/nosotros" class="transition-colors hover:text-cyan-400">Nosotros</a>
        <a href="/contacto" class="transition-colors hover:text-cyan-400">Contacto</a>
      </nav>
      
      <span class="h-3 w-[1px] bg-slate-800 hidden sm:inline"></span>
      
      <p class="text-slate-600 text-[11px] whitespace-nowrap">
        &copy; 2026 Todos los derechos reservados.
      </p>
    </div>

  </div>
</footer>