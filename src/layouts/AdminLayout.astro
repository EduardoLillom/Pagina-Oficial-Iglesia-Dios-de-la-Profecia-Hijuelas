---
// src/layouts/AdminLayout.astro
const { title } = Astro.props;
import '../styles/global.css';
---
<html lang="es">

  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | IDP Hijuelas - Admin</title>
  </head>


  <body class="flex min-h-screen bg-slate-50">
    <aside class="w-64 border-r border-slate-200 bg-white p-6 hidden md:block">
      <div class="mb-10 font-bold text-cyan-600">IDP ADMIN</div>
      <nav class="space-y-2">
        <a href="/admin" class="block px-4 py-2 rounded-xl hover:bg-slate-100">Dashboard</a>
        <p class="pt-4 pb-2 text-xs font-semibold text-slate-400 uppercase">Contenido</p>
        <a href="/admin/contenido-destacado" class="block px-4 py-2 rounded-xl hover:bg-slate-100">Contenido destacado</a>
        <a href="/admin/eventos" class="block px-4 py-2 rounded-xl hover:bg-slate-100">Eventos</a>
        </nav>
    </aside>

    <main class="flex-1 p-8">
      <slot />
    </main>
  </body>
</html>